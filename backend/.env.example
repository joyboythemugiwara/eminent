# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eminent_tutorials

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=mugi@eminentutorials.com
ADMIN_PASSWORD_HASH=will_be_set_during_setup

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=eminent-tutorials
R2_PUBLIC_URL=https://cdn.eminenttutorials.com

# Server
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001/api/v1
